{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "es2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",               // ← измени на react-jsx (лучше для Vite)
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]              // ← сузь до src, если алиас только для src
    },
    "types": ["node"]                 // ← оставляем
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "vite.config.ts"                  // ← обязательно для vite.config
  ],
  "exclude": ["node_modules", "dist"]
}